# คัดลอกไฟล์นี้เป็น .env แล้วเติมค่าจริง
# `cp .env.example .env`

# ── LINE Messaging API #1 — Doctor + Patient bot ──────────
# จาก LINE Developer Console → Channel
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=

# ── LINE Messaging API #2 — CRO Assistant bot (Phase 1A) ──
# Optional — ถ้าไม่ตั้ง endpoint /webhook/cro จะตอบ 503
# จาก LINE Developer Console → Channel ที่ 2 (สร้างใหม่)
LINE_CRO_CHANNEL_ID=
LINE_CRO_CHANNEL_SECRET=

# ── Dify ──────────────────────────────────────────────────
# host process ใช้ localhost; bridge container override เป็น http://api:5001/v1 ผ่าน compose
DIFY_API_URL=http://localhost/v1
# จาก Dify app "Patient Summary" → API Access
DIFY_API_KEY=
# จาก Dify Knowledge Base → API Access
DIFY_DATASET_API_KEY=
DIFY_DATASET_ID=

# ── Bridge ────────────────────────────────────────────────
SERVER_PORT=8000

# ── PostgreSQL (Dify ใช้ DB เดียวกัน) ──────────────────────
# host process ใช้ localhost:5433; bridge container override เป็น db_postgres:5432
DB_HOST=localhost
DB_PORT=5433
DB_NAME=hospital_db
DB_USER=postgres
DB_PASSWORD=<postgres-password>

# ── Gmail (email poller) ──────────────────────────────────
# App Password — ไม่ใช่รหัสผ่าน Gmail ปกติ (ต้อง enable 2FA + สร้างที่ myaccount.google.com/apppasswords)
GMAIL_EMAIL=
GMAIL_APP_PASSWORD=
EMAIL_POLL_INTERVAL=120

# ── ngrok ─────────────────────────────────────────────────
# จาก https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=
# Static domain ที่ขอจาก ngrok dashboard (free tier 1 อัน)
NGROK_PUBLIC_URL=https://your-static-domain.ngrok-free.dev
# Same domain without https://, used by the ngrok container command.
NGROK_DOMAIN=your-static-domain.ngrok-free.dev

# ── n8n automation layer (optional branch experiment) ──────────────
# Used by n8n/docker-compose.n8n.yaml. Keep workflows inactive until configured.
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://localhost:5678
N8N_WEBHOOK_URL=http://localhost:5678
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=
N8N_ENCRYPTION_KEY=
N8N_SECURE_COOKIE=false
BRIDGE_INTERNAL_URL=http://hospital-bridge:8000
BRIDGE_INTERNAL_TOKEN=
N8N_INTERNAL_BASE_URL=http://hospital-n8n:5678

# ── Google Calendar (Phase 1A.5 Level A — auto book) ──────
# Calendar ID จาก Settings → "Integrate calendar" → Calendar ID
# (รูปแบบ xxx@group.calendar.google.com หรือ user@gmail.com)
GOOGLE_CALENDAR_ID=
# Path ของ Service Account JSON ใน container (default ok, อย่าเปลี่ยน)
# Host ต้องวาง JSON ที่ ./credentials/service_account.json
GOOGLE_SERVICE_ACCOUNT_FILE=/app/credentials/service_account.json
