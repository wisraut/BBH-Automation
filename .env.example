# คัดลอกไฟล์นี้เป็น .env แล้วเติมค่าจริง
# `cp .env.example .env`

# ── LINE Messaging API #1 — Doctor + Patient bot ──────────
# จาก LINE Developer Console → Channel
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=

# ── LINE Messaging API #2 — CRO Assistant bot (Phase 1A) ──
# Optional — ถ้าไม่ตั้ง endpoint /webhook/cro จะตอบ 503
# จาก LINE Developer Console → Channel ที่ 2 (สร้างใหม่)
LINE_CRO_CHANNEL_ID=
LINE_CRO_CHANNEL_SECRET=

# ── Bridge ────────────────────────────────────────────────
SERVER_PORT=8000
JWT_SECRET=<random-32-plus-char-secret>
JWT_EXPIRE_HOURS=24

# ── PostgreSQL (legacy hospital_db) ──────────────────────
# host process ใช้ localhost:5433; bridge container override เป็น db_postgres:5432
DB_HOST=localhost
DB_PORT=5433
DB_NAME=hospital_db
DB_USER=postgres
DB_PASSWORD=<postgres-password>

# ── Gmail (email poller) ──────────────────────────────────
# App Password — ไม่ใช่รหัสผ่าน Gmail ปกติ (ต้อง enable 2FA + สร้างที่ myaccount.google.com/apppasswords)
GMAIL_EMAIL=
GMAIL_APP_PASSWORD=
EMAIL_POLL_INTERVAL=120

# Email ผู้รับ default ถ้า report ไม่ได้เลือกหมอ
REPORT_NOTIFY_EMAIL=

# ใช้ใน deep link ที่ส่งใน email แจ้ง doctor — ตั้งให้ตรงกับที่หมอเปิดได้จริง
#   dev (LAN office)   : http://172.25.x.x:5173
#   prod (tunnel)      : https://app.bbh-hospital.com
FRONTEND_BASE_URL=http://localhost:5173

# ── Public URL (Cloudflare Tunnel in production) ──────────
# The externally-reachable URL of this bridge. Used in startup logs
# and the / health endpoint. LINE Developer Console webhook should
# point at <PUBLIC_URL>/webhook.
#
# Production: the Cloudflare Tunnel hostname configured in the
#   Cloudflare dashboard, e.g. https://bridge.bbh-hospital.com.
#   cloudflared runs as a Windows service and routes the public URL
#   to localhost:8000 inside this machine.
# Dev (no tunnel): leave blank; the bridge falls back to
#   http://localhost:8000.
PUBLIC_URL=https://bridge.bbh-hospital.com

# ── n8n automation layer (optional branch experiment) ──────────────
# Used by n8n/docker-compose.n8n.yaml. Keep workflows inactive until configured.
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://localhost:5678
N8N_WEBHOOK_URL=http://localhost:5678
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=
N8N_ENCRYPTION_KEY=
N8N_SECURE_COOKIE=false
BRIDGE_INTERNAL_URL=http://hospital-bridge:8000
BRIDGE_INTERNAL_TOKEN=
N8N_INTERNAL_BASE_URL=http://hospital-n8n:5678

# ── Google Calendar (Phase 1A.5 Level A — auto book) ──────
# Calendar ID จาก Settings → "Integrate calendar" → Calendar ID
# (รูปแบบ xxx@group.calendar.google.com หรือ user@gmail.com)
GOOGLE_CALENDAR_ID=
# Path ของ Service Account JSON ใน container (default ok, อย่าเปลี่ยน)
# Host ต้องวาง JSON ที่ ./credentials/service_account.json
GOOGLE_SERVICE_ACCOUNT_FILE=/app/credentials/service_account.json

# Drop the cached conversation id when user has been idle >= N minutes.
# Prevents a single ESCALATE/CONSULT classification from sticking in the
# LLM memory window for the rest of the user's lifetime. Default 30.
BOT_SESSION_CONV_TTL_MIN=30

# ── AI Takeover (3-mode: auto/copilot/silent) ──────
# Sliding window: after CRO sends a LINE message, AI is auto-paused
# this many minutes (reset on each CRO reply). Default 30.
AI_AUTO_PAUSE_MINUTES=30
# CRO working hours in CRO_TIMEZONE. Outside this window, AI overrides
# the sticky per-patient mode (Auto/Copilot/Silent) and always replies
# — prevents patients being left in silence when no CRO is on duty.
CRO_BUSINESS_START=09:00
CRO_BUSINESS_END=18:00
CRO_TIMEZONE=Asia/Bangkok

# LLM backend for all AI (LINE routing + Web /ai + patient summary) via OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash-lite
# Own-RAG embedder model (matches the bbh-embedder Infinity container model-id)
EMBED_MODEL=BAAI/bge-m3
