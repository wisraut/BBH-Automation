              "value": "={{$env.BRIDGE_INTERNAL_TOKEN}}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{$json}}"
      },
      "id": "send-to-bridge",
      "name": "Send To Bridge",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [520, 0]
    }
  ],
  "connections": {
    "Manual Trigger": {
      "main": [[{"node": "Shape Report Payload", "type": "main", "index": 0}]]
    },
    "Shape Report Payload": {
      "main": [[{"node": "Send To Bridge", "type": "main", "index": 0}]]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
