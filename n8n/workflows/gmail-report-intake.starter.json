{
  "name": "Hospital Gmail Report Intake - Starter",
  "active": false,
  "nodes": [
    {
      "parameters": {},
      "id": "manual-trigger",
      "name": "Manual Trigger",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [0, 0]
    },
    {
      "parameters": {
        "jsCode": "return items.map((item) => ({ json: { source: 'n8n-starter', note: 'Replace this node with Gmail Trigger + Gmail message/attachment parsing before activation.', receivedAt: new Date().toISOString() } }));"
      },
      "id": "shape-report-payload",
      "name": "Shape Report Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [260, 0]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.BRIDGE_INTERNAL_URL}}/internal/reports/from-email",
        "sendHeaders": true,
        "headerParameters": {
