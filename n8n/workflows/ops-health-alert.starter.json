      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        660,
        -180
      ],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": false,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond-follow",
              "leftValue": "={{ $json.event_type }}",
              "rightValue": "follow",
              "operator": {
