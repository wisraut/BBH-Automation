      "id": "n3-line1-parse",
      "name": "Parse Events",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        440,
        -180
      ],
      "parameters": {
        "jsCode": "const body = $input.first().json.body ?? $input.first().json;\nconst events = (body.events ?? []).filter(\n  e => ['message', 'follow', 'postback'].includes(e.type)\n);\nif (!events.length) return [];\nreturn events.map(e => ({\n  json: {\n    event_type:  e.type,\n    user_id:     e.source?.userId ?? '',\n    reply_token: e.replyToken ?? '',\n    text:        e.message?.text ?? e.postback?.data ?? ''\n  }\n}));"
      }
    },
    {
      "id": "n4-line1-if-follow",
      "name": "Is Follow?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        660,
        -180
      ],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": false,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond-follow",
              "leftValue": "={{ $json.event_type }}",
              "rightValue": "follow",
              "operator": {
                "type": "string",
                "operation": "equals",
                "name": "filter.operator.equals"
              }
            }
          ],
          "combinator": "and"
        }
      }
    },
    {
      "id": "n5-line1-welcome",
      "name": "Send Welcome",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
        -320
      ],
      "parameters": {
        "jsCode": "const { reply_token } = $json;\n\nasync function getToken(id, sec) {\n  const r = await fetch('https://api.line.me/v2/oauth/accessToken', {\n    method: 'POST',\n    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },\n    body: `grant_type=client_credentials&client_id=${encodeURIComponent(id)}&client_secret=${encodeURIComponent(sec)}`\n  });\n  return (await r.json()).access_token;\n}\n\nconst token = await getToken(\n  $vars.LINE_CHANNEL_ID ?? '',\n  $vars.LINE_CHANNEL_SECRET ?? ''\n);\n\nawait fetch('https://api.line.me/v2/bot/message/reply', {\n  method: 'POST',\n  headers: { Authorization: `Bearer ${token}`, 'Content-Type': 'application/json' },\n  body: JSON.stringify({\n    replyToken: reply_token,\n    messages: [{\n      type: 'text',\n      text: 'à¸ªà¸§à¸±à¸ªà¸”à¸µà¸„à¹ˆà¸° ðŸ‘‹ à¸¢à¸´à¸™à¸”à¸µà¸•à¹‰à¸­à¸™à¸£à¸±à¸šà¸ªà¸¹à¹ˆ BBH Functional Medicine\\n\\nà¸žà¸´à¸¡à¸žà¹Œà¸„à¸³à¸–à¸²à¸¡à¹„à¸”à¹‰à¹€à¸¥à¸¢ à¸«à¸£à¸·à¸­à¹€à¸¥à¸·à¸­à¸à¸«à¸±à¸§à¸‚à¹‰à¸­à¸—à¸µà¹ˆà¸ªà¸™à¹ƒà¸ˆ:',\n      quickReply: {\n        items: [\n          { type: 'action', action: { type: 'message', label: 'ðŸ“… à¸ˆà¸­à¸‡à¸„à¸´à¸§',           text: 'à¸­à¸¢à¸²à¸à¸ˆà¸­à¸‡à¸„à¸´à¸§' } },\n          { type: 'action', action: { type: 'message', label: 'ðŸ”¬ FM à¸„à¸·à¸­à¸­à¸°à¹„à¸£',       text: 'Functional Medicine à¸„à¸·à¸­à¸­à¸°à¹„à¸£' } },\n          { type: 'action', action: { type: 'message', label: 'ðŸ’Š à¸šà¸£à¸´à¸à¸²à¸£à¹à¸¥à¸°à¸£à¸²à¸„à¸²',    text: 'à¸šà¸£à¸´à¸à¸²à¸£à¹à¸¥à¸°à¸£à¸²à¸„à¸²' } },\n          { type: 'action', action: { type: 'message', label: 'ðŸ“‹ à¸§à¸´à¸˜à¸µà¸ªà¹ˆà¸‡à¸œà¸¥à¸•à¸£à¸§à¸ˆ',   text: 'à¸§à¸´à¸˜à¸µà¸ªà¹ˆà¸‡à¸œà¸¥à¸•à¸£à¸§à¸ˆ' } }\n        ]\n      }\n    }]\n  })\n});\n\nreturn [{ json: { ok: true, sent: 'welcome' } }];"
      }
    },
