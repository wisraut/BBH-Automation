                "operation": "equals",
                "name": "filter.operator.equals"
              }
            }
          ],
          "combinator": "and"
        }
      }
    },
    {
      "id": "n5-line1-welcome",
      "name": "Send Welcome",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
        -320
      ],
      "parameters": {
        "jsCode": "const { reply_token } = $json;\n\nasync function getToken(id, sec) {\n  const r = await fetch('https://api.line.me/v2/oauth/accessToken', {\n    method: 'POST',\n    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },\n    body: `grant_type=client_credentials&client_id=${encodeURIComponent(id)}&client_secret=${encodeURIComponent(sec)}`\n  });\n  return (await r.json()).access_token;\n}\n\nconst token = await getToken(\n  $vars.LINE_CHANNEL_ID ?? '',\n  $vars.LINE_CHANNEL_SECRET ?? ''\n);\n\nawait fetch('https://api.line.me/v2/bot/message/reply', {\n  method: 'POST',\n  headers: { Authorization: `Bearer ${token}`, 'Content-Type': 'application/json' },\n  body: JSON.stringify({\n    replyToken: reply_token,\n    messages: [{\n      type: 'text',\n      text: 'ร ยธยชร ยธยงร ยธยฑร ยธยชร ยธโร ยธยตร ยธโร ยนหร ยธยฐ รฐลธโโน ร ยธยขร ยธยดร ยธโขร ยธโร ยธยตร ยธโขร ยนโฐร ยธยญร ยธโขร ยธยฃร ยธยฑร ยธลกร ยธยชร ยธยนร ยนห BBH Functional Medicine\\n\\nร ยธลพร ยธยดร ยธยกร ยธลพร ยนลร ยธโร ยธยณร ยธโร ยธยฒร ยธยกร ยนโร ยธโร ยนโฐร ยนโฌร ยธยฅร ยธยข ร ยธยซร ยธยฃร ยธยทร ยธยญร ยนโฌร ยธยฅร ยธยทร ยธยญร ยธยร ยธยซร ยธยฑร ยธยงร ยธโร ยนโฐร ยธยญร ยธโร ยธยตร ยนหร ยธยชร ยธโขร ยนฦร ยธห:',\n      quickReply: {\n        items: [\n          { type: 'action', action: { type: 'message', label: 'รฐลธโโฆ ร ยธหร ยธยญร ยธโกร ยธโร ยธยดร ยธยง',           text: 'ร ยธยญร ยธยขร ยธยฒร ยธยร ยธหร ยธยญร ยธโกร ยธโร ยธยดร ยธยง' } },\n          { type: 'action', action: { type: 'message', label: 'รฐลธโยฌ FM ร ยธโร ยธยทร ยธยญร ยธยญร ยธยฐร ยนโร ยธยฃ',       text: 'Functional Medicine ร ยธโร ยธยทร ยธยญร ยธยญร ยธยฐร ยนโร ยธยฃ' } },\n          { type: 'action', action: { type: 'message', label: 'รฐลธโล  ร ยธลกร ยธยฃร ยธยดร ยธยร ยธยฒร ยธยฃร ยนยร ยธยฅร ยธยฐร ยธยฃร ยธยฒร ยธโร ยธยฒ',    text: 'ร ยธลกร ยธยฃร ยธยดร ยธยร ยธยฒร ยธยฃร ยนยร ยธยฅร ยธยฐร ยธยฃร ยธยฒร ยธโร ยธยฒ' } },\n          { type: 'action', action: { type: 'message', label: 'รฐลธโโน ร ยธยงร ยธยดร ยธหร ยธยตร ยธยชร ยนหร ยธโกร ยธลร ยธยฅร ยธโขร ยธยฃร ยธยงร ยธห',   text: 'ร ยธยงร ยธยดร ยธหร ยธยตร ยธยชร ยนหร ยธโกร ยธลร ยธยฅร ยธโขร ยธยฃร ยธยงร ยธห' } }\n        ]\n      }\n    }]\n  })\n});\n\nreturn [{ json: { ok: true, sent: 'welcome' } }];"
      }
    },
